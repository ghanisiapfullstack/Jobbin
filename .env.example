APP_NAME=Jobbin
APP_ENV=local
APP_KEY=
APP_DEBUG=true

LOG_CHANNEL=stack
LOG_LEVEL=debug

APP_URL=http://localhost
APP_HOST=127.0.0.1
APP_PORT=3000

JWT_SECRET=

# Database
DB_CONNECTION=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=jobbin
DB_USERNAME=jobbin
DB_PASSWORD=jobbin_secret

# Resend Email
RESEND_API_KEY=your_resend_api_key_here
MAIL_FROM_ADDRESS=noreply@jobbin.app
MAIL_FROM_NAME=Jobbin

# Frontend URL (untuk link di email)
FRONTEND_URL=http://localhost:5173
